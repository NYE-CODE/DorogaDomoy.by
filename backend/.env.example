# Секретный ключ для JWT (обязательно поменять!)
SECRET_KEY=сгенерируй-длинный-случайный-ключ
AUTH_COOKIE_NAME=dorogadomoy_session
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# Разрешённые домены для CORS (через запятую)
ALLOWED_ORIGINS=https://dorogadomoy.by,https://www.dorogadomoy.by,http://localhost:3000
TRUST_PROXY_HEADERS=false

# Путь к базе данных
# Локально: sqlite:///./petfinder.db
# Продакшен (директория с правами на запись): sqlite:////var/lib/dorogadomoy/petfinder.db
DATABASE_URL=sqlite:///./petfinder.db

# Telegram Bot (получить у @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=dorogadomoy_by_bot
TELEGRAM_WEBHOOK_SECRET=сгенерируй-длинный-секрет-для-webhook

# URL сайта (для ссылок в уведомлениях)
SITE_URL=https://dorogadomoy.by
